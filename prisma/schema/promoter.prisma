// Prisma Schema - Promoters & Referrals
// Promoter, referral tracking, commissions, and tier system

model Promoter {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String         @unique @map("user_id") @db.Uuid
  referralCode        String         @unique @map("referral_code")
  status              PromoterStatus @default(pending)
  commissionRate      Decimal        @default(5.00) @map("commission_rate") @db.Decimal(5, 2)
  tier                Int            @default(1)
  totalReferrals      Int            @default(0) @map("total_referrals")
  successfulReferrals Int            @default(0) @map("successful_referrals")
  totalEarnings       Decimal        @default(0) @map("total_earnings") @db.Decimal(15, 2)
  pendingEarnings     Decimal        @default(0) @map("pending_earnings") @db.Decimal(15, 2)
  phoneNumber         String?        @map("phone_number")
  bankName            String?        @map("bank_name")
  bankAccountNumber   String?        @map("bank_account_number")
  bankAccountName     String?        @map("bank_account_name")
  approvedAt          DateTime?      @map("approved_at") @db.Timestamptz
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user          Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals     Referral[]
  commissions   Commission[]
  referredUsers Profile[]    @relation("ReferredUsers")

  @@index([userId], name: "idx_promoters_user")
  @@index([referralCode], name: "idx_promoters_code")
  @@index([status], name: "idx_promoters_status")
  @@map("promoters")
}

model Referral {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  promoterId       String         @map("promoter_id") @db.Uuid
  referredUserId   String?        @map("referred_user_id") @db.Uuid
  referredEmail    String?        @map("referred_email")
  referralCodeUsed String         @map("referral_code_used")
  status           ReferralStatus @default(pending)
  source           String?
  campaign         String?
  landingPage      String?        @map("landing_page")
  ipAddress        String?        @map("ip_address") @db.Inet
  userAgent        String?        @map("user_agent")
  convertedAt      DateTime?      @map("converted_at") @db.Timestamptz
  firstPurchaseAt  DateTime?      @map("first_purchase_at") @db.Timestamptz
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  promoter     Promoter     @relation(fields: [promoterId], references: [id], onDelete: Cascade)
  referredUser Profile?     @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: SetNull)
  commissions  Commission[]

  @@index([promoterId], name: "idx_referrals_promoter")
  @@index([referredUserId], name: "idx_referrals_user")
  @@index([referralCodeUsed], name: "idx_referrals_code")
  @@index([status], name: "idx_referrals_status")
  @@map("referrals")
}

model Commission {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  promoterId       String           @map("promoter_id") @db.Uuid
  referralId       String?          @map("referral_id") @db.Uuid
  type             CommissionType
  status           CommissionStatus @default(pending)
  amount           Decimal          @db.Decimal(15, 2)
  currency         String           @default("NGN")
  sourceType       String?          @map("source_type")
  sourceId         String?          @map("source_id") @db.Uuid
  baseAmount       Decimal?         @map("base_amount") @db.Decimal(15, 2)
  commissionRate   Decimal?         @map("commission_rate") @db.Decimal(5, 2)
  description      String?
  processedAt      DateTime?        @map("processed_at") @db.Timestamptz
  paidAt           DateTime?        @map("paid_at") @db.Timestamptz
  paymentReference String?          @map("payment_reference")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  promoter Promoter  @relation(fields: [promoterId], references: [id], onDelete: Cascade)
  referral Referral? @relation(fields: [referralId], references: [id], onDelete: SetNull)

  @@index([promoterId], name: "idx_commissions_promoter")
  @@index([referralId], name: "idx_commissions_referral")
  @@index([status], name: "idx_commissions_status")
  @@index([type], name: "idx_commissions_type")
  @@map("commissions")
}

model PromoterTier {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tierLevel      Int      @unique @map("tier_level")
  name           String
  minReferrals   Int      @default(0) @map("min_referrals")
  minEarnings    Decimal  @default(0) @map("min_earnings") @db.Decimal(15, 2)
  commissionRate Decimal  @map("commission_rate") @db.Decimal(5, 2)
  bonusRate      Decimal  @default(0) @map("bonus_rate") @db.Decimal(5, 2)
  description    String?
  perks          Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("promoter_tiers")
}
