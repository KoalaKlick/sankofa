// Prisma Schema - Tickets
// Ticket types, orders, and individual tickets

model TicketType {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId       String       @map("event_id") @db.Uuid
  name          String
  description   String?
  price         Decimal      @default(0) @db.Decimal(10, 2)
  currency      String       @default("NGN")
  quantityTotal Int?         @map("quantity_total")
  quantitySold  Int          @default(0) @map("quantity_sold")
  salesStart    DateTime?    @map("sales_start") @db.Timestamptz
  salesEnd      DateTime?    @map("sales_end") @db.Timestamptz
  maxPerOrder   Int          @default(10) @map("max_per_order")
  minPerOrder   Int          @default(1) @map("min_per_order")
  status        TicketStatus @default(available)
  orderIdx      Int          @default(0) @map("order_idx")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets Ticket[]

  @@index([eventId], name: "idx_ticket_types_event")
  @@index([status], name: "idx_ticket_types_status")
  @@map("ticket_types")
}

model TicketOrder {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId          String      @map("event_id") @db.Uuid
  buyerId          String?     @map("buyer_id") @db.Uuid
  orderNumber      String      @unique @map("order_number")
  buyerEmail       String      @map("buyer_email")
  buyerName        String?     @map("buyer_name")
  buyerPhone       String?     @map("buyer_phone")
  subtotal         Decimal     @db.Decimal(10, 2)
  discountAmount   Decimal     @default(0) @map("discount_amount") @db.Decimal(10, 2)
  fees             Decimal     @default(0) @db.Decimal(10, 2)
  total            Decimal     @db.Decimal(10, 2)
  currency         String      @default("NGN")
  paymentMethod    String?     @map("payment_method")
  paymentReference String?     @map("payment_reference")
  paidAt           DateTime?   @map("paid_at") @db.Timestamptz
  status           OrderStatus @default(pending)
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  buyer   Profile? @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  tickets Ticket[]

  @@index([eventId], name: "idx_ticket_orders_event")
  @@index([buyerId], name: "idx_ticket_orders_buyer")
  @@index([status], name: "idx_ticket_orders_status")
  @@index([orderNumber], name: "idx_ticket_orders_number")
  @@map("ticket_orders")
}

model Ticket {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String              @map("order_id") @db.Uuid
  eventId       String              @map("event_id") @db.Uuid
  ticketTypeId  String              @map("ticket_type_id") @db.Uuid
  ticketCode    String              @unique @map("ticket_code")
  attendeeName  String?             @map("attendee_name")
  attendeeEmail String?             @map("attendee_email")
  checkInStatus TicketCheckInStatus @default(not_checked_in) @map("check_in_status")
  checkedInAt   DateTime?           @map("checked_in_at") @db.Timestamptz
  checkedInBy   String?             @map("checked_in_by") @db.Uuid
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  order           TicketOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  event           Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType      TicketType  @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  checkedInByUser Profile?    @relation("CheckedInTickets", fields: [checkedInBy], references: [id])

  @@index([orderId], name: "idx_tickets_order")
  @@index([eventId], name: "idx_tickets_event")
  @@index([ticketTypeId], name: "idx_tickets_type")
  @@index([ticketCode], name: "idx_tickets_code")
  @@index([checkInStatus], name: "idx_tickets_check_in")
  @@map("tickets")
}
