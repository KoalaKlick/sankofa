// Prisma Schema - Voting
// Voting categories, options, and votes

model VotingCategory {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId         String  @map("event_id") @db.Uuid
  name            String
  description     String?
  orderIdx        Int     @default(0) @map("order_idx")
  maxVotesPerUser Int     @default(1) @map("max_votes_per_user")
  allowMultiple   Boolean @default(false) @map("allow_multiple")

  // Template settings
  templateImage  String?  @map("template_image") // Background template image URL
  templateConfig Json?    @map("template_config") // JSON with position/size settings for nominee photo overlay
  showFinalImage Boolean  @default(true) @map("show_final_image") // Show finalImage (with template) on cards instead of imageUrl

  // Public nomination settings
  allowPublicNomination Boolean   @default(false) @map("allow_public_nomination")
  nominationDeadline    DateTime? @map("nomination_deadline") @db.Timestamptz
  requireApproval       Boolean   @default(true) @map("require_approval") // Admin must approve public nominations

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  event         Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  votingOptions VotingOption[]
  votes         Vote[]
  customFields  VotingCategoryField[]

  @@index([eventId], name: "idx_voting_categories_event")
  @@map("voting_categories")
}

// Custom fields that admin can define per category
model VotingCategoryField {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  fieldName   String   @map("field_name")
  fieldType   String   @default("text") @map("field_type") // text, email, phone, url, textarea, select
  fieldLabel  String   @map("field_label")
  placeholder String?
  isRequired  Boolean  @default(false) @map("is_required")
  options     String[] @default([]) // For select type fields
  orderIdx    Int      @default(0) @map("order_idx")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  category VotingCategory           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  values   VotingOptionFieldValue[]

  @@index([categoryId], name: "idx_voting_category_fields_category")
  @@map("voting_category_fields")
}

model VotingOption {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId    String  @map("event_id") @db.Uuid
  categoryId String? @map("category_id") @db.Uuid

  // Basic nominee info
  optionText  String  @map("option_text") // Nominee name
  nomineeCode String? @map("nominee_code") // Unique code like "NOM001"
  email       String? // Nominee's email
  description String?
  imageUrl    String? @map("image_url") // Original nominee photo
  finalImage  String? @map("final_image") // Combined image with template

  // Status and ordering
  orderIdx   Int                @default(0) @map("order_idx")
  votesCount BigInt             @default(0) @map("votes_count")
  status     VotingOptionStatus @default(approved) // For public nominations

  // Public nomination tracking
  isPublicNomination Boolean @default(false) @map("is_public_nomination")
  nominatedById      String? @map("nominated_by_id") @db.Uuid
  nominatedByEmail   String? @map("nominated_by_email")
  nominatedByName    String? @map("nominated_by_name")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  event       Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category    VotingCategory?          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  votes       Vote[]
  fieldValues VotingOptionFieldValue[]
  nominatedBy Profile?                 @relation("NominatedOptions", fields: [nominatedById], references: [id], onDelete: SetNull)

  @@unique([eventId, nomineeCode])
  @@index([eventId], name: "idx_voting_options_event")
  @@index([categoryId], name: "idx_voting_options_category")
  @@index([status], name: "idx_voting_options_status")
  @@map("voting_options")
}

// Store values for custom fields
model VotingOptionFieldValue {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  optionId  String   @map("option_id") @db.Uuid
  fieldId   String   @map("field_id") @db.Uuid
  value     String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  option VotingOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)
  field  VotingCategoryField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([optionId, fieldId])
  @@index([optionId], name: "idx_voting_option_field_values_option")
  @@map("voting_option_field_values")
}

enum VotingOptionStatus {
  pending // Awaiting admin approval (public nominations)
  approved // Approved and visible
  rejected // Rejected by admin

  @@map("voting_option_status")
}

model Vote {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId          String   @map("event_id") @db.Uuid
  optionId         String   @map("option_id") @db.Uuid
  categoryId       String?  @map("category_id") @db.Uuid
  voterId          String?  @map("voter_id") @db.Uuid
  voterEmail       String?  @map("voter_email")
  voterIp          String?  @map("voter_ip") @db.Inet
  amountPaid       Decimal  @default(0) @map("amount_paid") @db.Decimal(10, 2)
  paymentReference String?  @map("payment_reference")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  event    Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  option   VotingOption    @relation(fields: [optionId], references: [id], onDelete: Cascade)
  category VotingCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  voter    Profile?        @relation(fields: [voterId], references: [id], onDelete: SetNull)

  @@unique([eventId, optionId, voterId])
  @@index([eventId], name: "idx_votes_event")
  @@index([optionId], name: "idx_votes_option")
  @@index([voterId], name: "idx_votes_voter")
  @@index([createdAt], name: "idx_votes_created_at")
  @@map("votes")
}
